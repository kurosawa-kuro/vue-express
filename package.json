{
  "name": "vue-express",
  "version": "1.0.0",
  "description": "Vue 3 + Express + Prisma fullstack sample application",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd src/frontend && npm run dev",
    "dev:backend": "cd src/backend && npm run dev",
    "install:all": "npm install && cd src/frontend && npm install && cd ../backend && npm install",
    "build": "cd src/frontend && npm run build",
    "db:migrate": "cd src/backend && npm run db:migrate",
    "db:generate": "cd src/backend && npm run db:generate",
    "db:seed": "cd src/backend && npm run db:seed"
  },
  "keywords": ["vue", "express", "prisma", "fullstack"],
  "author": "Toshifumi Kurosawa",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
